<section class="bg-light py-5">

    <div class="container">

        <!-- Heading -->

        <div class="text-center mb-5">

            <i class="bi bi-heart-fill display-4 text-danger"></i>

            <h2 class="fw-bold mt-3">
                My Wishlist
            </h2>

            <p class="text-muted">
                Save your favorite products and shop them anytime.
            </p>

        </div>

        <!-- Empty Wishlist -->

        <% if(items.length === 0){ %>

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center py-5">

                    <i class="bi bi-heart display-1 text-secondary"></i>

                    <h3 class="mt-3">
                        Your Wishlist is Empty
                    </h3>

                    <p class="text-muted">
                        Browse our latest collection and add products you love.
                    </p>

                    <a
                        href="/api/products"
                        class="btn btn-warning btn-lg mt-2"
                    >

                        <i class="bi bi-bag-fill me-2"></i>

                        Continue Shopping

                    </a>

                </div>

            </div>

        <% } else { %>

            <div class="row g-4">

                <% items.forEach(item=>{ %>

                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">

                        <div class="card h-100 border-0 shadow-sm">

                            <img
                                src="/uploads/<%= item.product.thumbnail %>"
                                class="card-img-top"
                                style="height:240px;object-fit:cover;"
                                alt="<%= item.product.name %>"
                            >

                            <div class="card-body d-flex flex-column">

                                <span class="badge bg-danger align-self-start mb-2">
                                    Wishlist
                                </span>

                                <h5 class="fw-bold">
                                    <%= item.product.name %>
                                </h5>

                                <h4 class="text-success fw-bold mb-4">
                                    ₹<%= item.product.price %>
                                </h4>

                                <div class="mt-auto">

                                    <!-- Add To Cart -->

                                    <form
                                        action="/api/cart"
                                        method="POST"
                                        class="mb-2"
                                    >

                                        <input
                                            type="hidden"
                                            name="productId"
                                            value="<%= item.product._id %>"
                                        >

                                        <input
                                            type="hidden"
                                            name="quantity"
                                            value="1"
                                        >

                                        <button
                                            class="btn btn-warning w-100"
                                        >

                                            <i class="bi bi-cart-plus-fill me-2"></i>

                                            Add to Cart

                                        </button>

                                    </form>

                                    <!-- Remove -->

                                    <form
                                        action="/api/wishlist/delete/<%= item._id %>"
                                        method="POST"
                                    >

                                        <button
                                            class="btn btn-outline-danger w-100"
                                        >

                                            <i class="bi bi-trash-fill me-2"></i>

                                            Remove

                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

</section>