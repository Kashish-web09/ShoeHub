<section class="bg-light d-flex align-items-center justify-content-center py-5" style="min-height:90vh;">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-12 col-sm-10 col-md-8 col-lg-5">

                <div class="card border-0 shadow">

                    <div class="card-body p-4 p-md-5">

                        <!-- Icon -->
                        <div class="text-center mb-4">

                            <div class="mb-3">
                                <i class="bi bi-shield-lock-fill display-4 text-warning"></i>
                            </div>

                            <h2 class="fw-bold">
                                Forgot Password?
                            </h2>

                            <p class="text-muted mb-0">
                                Enter your registered email address and we'll send you a password reset link.
                            </p>

                        </div>

                        <!-- Form -->
                        <form action="/api/users/forgotPass" method="POST">

                            <div class="mb-4">

                                <label class="form-label">
                                    Email Address
                                </label>

                                <input
                                    type="email"
                                    name="email"
                                    class="form-control form-control-lg"
                                    placeholder="Enter your email"
                                    required
                                >

                            </div>

                            <div class="d-grid">

                                <button
                                    type="submit"
                                    class="btn btn-warning btn-lg"
                                >

                                    <i class="bi bi-envelope-paper me-2"></i>

                                    Send Reset Link

                                </button>

                            </div>

                        </form>

                        <hr class="my-4">

                        <div class="text-center">

                            <a
                                href="/api/users/login"
                                class="text-decoration-none fw-semibold"
                            >
                                <i class="bi bi-arrow-left"></i>
                                Back to Login
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>