<section class="cart-page py-5 bg-light">

    <div class="container">

        <!-- Heading -->
        <div class="text-center mb-5">
            <h2 class="fw-bold">Shopping Cart</h2>
            <p class="text-muted mb-0">
                Review your items before checkout.
            </p>
        </div>

        <div class="card shadow border-0">

            <div class="card-body p-0">

                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="table-dark text-center">

                            <tr>
                                <th class="ps-4 text-start">Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Subtotal</th>
                                <th class="pe-4">Action</th>
                            </tr>

                        </thead>

                        <tbody>

                            <% if(items && items.length>0){ %>

                                <% items.forEach(item=>{ %>

                                    <tr>

                                        <% if(item.product){ %>

                                            <!-- Product -->
                                            <td class="ps-4">

                                                <div class="d-flex align-items-center gap-3">

                                                    <% if(item.product.images && item.product.images.length>0){ %>

                                                        <img
                                                            src="/uploads/<%= item.product.images[0] %>"
                                                            class="rounded border"
                                                            width="80"
                                                            height="80"
                                                            style="object-fit:cover;"
                                                        >

                                                    <% }else{ %>

                                                        <img
                                                            src="/uploads/default.png"
                                                            class="rounded border"
                                                            width="80"
                                                            height="80"
                                                        >

                                                    <% } %>

                                                    <div class="text-start">

                                                        <h6 class="mb-1 fw-semibold">
                                                            <%= item.product.name %>
                                                        </h6>

                                                    </div>

                                                </div>

                                            </td>

                                            <!-- Price -->
                                            <td class="text-center fw-semibold">
                                                ₹<%= item.product.price %>
                                            </td>

                                            <!-- Quantity -->
                                            <td>

                                                <div class="d-flex justify-content-center align-items-center gap-2">

                                                    <form action="/api/cart/decrease/<%= item._id %>" method="post">
                                                        <button class="btn btn-outline-secondary btn-sm">
                                                            <i class="bi bi-dash-lg"></i>
                                                        </button>
                                                    </form>

                                                    <span class="fw-bold px-2">
                                                        <%= item.quantity %>
                                                    </span>

                                                    <form action="/api/cart/increase/<%= item._id %>" method="post">
                                                        <button class="btn btn-outline-secondary btn-sm">
                                                            <i class="bi bi-plus-lg"></i>
                                                        </button>
                                                    </form>

                                                </div>

                                            </td>

                                            <!-- Subtotal -->
                                            <td class="text-center fw-bold text-success">
                                                ₹<%= item.product.price * item.quantity %>
                                            </td>

                                        <% }else{ %>

                                            <td colspan="4" class="text-danger text-center">
                                                Product no longer available
                                            </td>

                                        <% } %>

                                        <!-- Remove -->
                                        <td class="text-center pe-4">

                                            <form
                                                action="/api/cart/<%= item._id %>?_method=DELETE"
                                                method="POST"
                                            >

                                                <button class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-trash3"></i>
                                                    Remove
                                                </button>

                                            </form>

                                        </td>

                                    </tr>

                                <% }) %>

                            <% }else{ %>

                                <tr>

                                    <td colspan="5" class="text-center py-5">

                                        <i class="bi bi-cart-x display-4 text-secondary"></i>

                                        <h5 class="mt-3">
                                            Your cart is empty
                                        </h5>

                                        <a href="/api/products" class="btn btn-warning mt-3">
                                            Continue Shopping
                                        </a>

                                    </td>

                                </tr>

                            <% } %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Total Section -->
        <% if(items && items.length>0){ %>

        <div class="card shadow-sm border-0 mt-4">

            <div class="card-body">

                <div class="row align-items-center">

                    <div class="col-md-6 text-center text-md-start">

                        <h4 class="mb-0">
                            Total :
                            <span class="text-success fw-bold">
                                ₹ <%= total || 0 %>
                            </span>
                        </h4>

                    </div>

                    <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">

                        <a
                            href="/api/orders/checkout"
                            class="btn btn-warning btn-lg px-4"
                        >
                            Proceed to Checkout
                        </a>

                    </div>

                </div>

            </div>

        </div>

        <% } %>

    </div>

</section>