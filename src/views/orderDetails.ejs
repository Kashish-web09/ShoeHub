<div class="container py-5">

    <!-- Page Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-box-seam-fill text-warning"></i>
                Order Details
            </h2>

            <p class="text-muted mb-0">
                Review your order information and shipping details.
            </p>
        </div>

        <a
            href="/api/orders"
            class="btn btn-outline-dark mt-3 mt-md-0"
        >
            <i class="bi bi-arrow-left"></i>
            Back to Orders
        </a>

    </div>

    <div class="row g-4">

        <!-- LEFT SIDE -->
        <div class="col-lg-8">

            <!-- Order Information -->
            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        Order Information
                    </h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <small class="text-muted">
                                Order ID
                            </small>

                            <div class="fw-semibold">
                                <%= order._id %>
                            </div>

                        </div>

                        <div class="col-md-6 mb-3">

                            <small class="text-muted">
                                Order Date
                            </small>

                            <div class="fw-semibold">
                                <%= new Date(order.createdAt).toLocaleString() %>
                            </div>

                        </div>

                        <div class="col-md-6 mb-3">

                            <small class="text-muted">
                                Order Status
                            </small>

                            <div>

                                <span class="badge bg-success px-3 py-2">
                                    <%= order.orderStatus %>
                                </span>

                            </div>

                        </div>

                        <div class="col-md-6 mb-3">

                            <small class="text-muted">
                                Payment Method
                            </small>

                            <div class="fw-semibold">
                                <%= order.paymentMethod %>
                            </div>

                        </div>

                        <div class="col-md-6 mb-3">

                            <small class="text-muted">
                                Payment Status
                            </small>

                            <div>

                                <% if(order.paymentStatus==="Paid"){ %>

                                <span class="badge bg-success px-3 py-2">
                                    Paid
                                </span>

                                <% } else { %>

                                <span class="badge bg-warning text-dark px-3 py-2">
                                    Pending
                                </span>

                                <% } %>

                            </div>

                        </div>

                        <div class="col-md-6 mb-3">

                            <small class="text-muted">
                                Total Amount
                            </small>

                            <div class="fs-4 fw-bold text-success">
                                ₹<%= order.totalAmount %>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Ordered Products -->

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-success text-white">

                    <h5 class="mb-0">
                        Ordered Products
                    </h5>

                </div>

                <div class="card-body">

                    <% order.items.forEach(item=>{ %>

                    <div class="row align-items-center border-bottom py-3">

                        <div class="col-3 col-md-2">

                            <img
                                src="/uploads/<%= item.image %>"
                                class="img-fluid rounded border"
                                style="height:80px;object-fit:cover;"
                            >

                        </div>

                        <div class="col-9 col-md-4">

                            <h6 class="fw-bold mb-1">
                                <%= item.productName %>
                            </h6>

                        </div>

                        <div class="col-4 col-md-2 mt-3 mt-md-0">

                            <small class="text-muted">
                                Price
                            </small>

                            <div>
                                ₹<%= item.price %>
                            </div>

                        </div>

                        <div class="col-4 col-md-2 mt-3 mt-md-0">

                            <small class="text-muted">
                                Qty
                            </small>

                            <div>
                                <%= item.quantity %>
                            </div>

                        </div>

                        <div class="col-4 col-md-2 mt-3 mt-md-0 text-md-end">

                            <small class="text-muted">
                                Total
                            </small>

                            <div class="fw-bold text-success">
                                ₹<%= item.subtotal %>
                            </div>

                        </div>

                    </div>

                    <% }) %>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->

        <div class="col-lg-4">

            <!-- Shipping -->

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-info text-white">

                    <h5 class="mb-0">
                        Shipping Address
                    </h5>

                </div>

                <div class="card-body">

                    <h6 class="fw-bold">
                        <%= order.shippingAddress.fullName %>
                    </h6>

                    <p class="mb-2 text-muted">

                        <%= order.shippingAddress.address %>

                    </p>

                    <p class="mb-2">

                        <%= order.shippingAddress.city %>,
                        <%= order.shippingAddress.state %>

                        -

                        <%= order.shippingAddress.pincode %>

                    </p>

                    <p class="mb-0">

                        <i class="bi bi-telephone"></i>

                        <%= order.shippingAddress.phone %>

                    </p>

                </div>

            </div>

            <!-- Summary -->

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-warning">

                    <h5 class="mb-0">
                        Order Summary
                    </h5>

                </div>

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">

                        <span>
                            Grand Total
                        </span>

                        <span class="fw-bold text-success fs-4">

                            ₹<%= order.totalAmount %>

                        </span>

                    </div>

                    <hr>

                    <div class="text-success">

                        <i class="bi bi-patch-check-fill"></i>

                        Thank you for shopping with us!

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>