<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">
                Order Details
            </h2>

            <p class="text-muted mb-0">
                View your order information and purchased products.
            </p>

        </div>

        <%
            let badge = "bg-secondary";

            if(order.orderStatus==="Placed"){
                badge="bg-warning text-dark";
            }else if(order.orderStatus==="Processing"){
                badge="bg-info";
            }else if(order.orderStatus==="Shipped"){
                badge="bg-primary";
            }else if(order.orderStatus==="Delivered"){
                badge="bg-success";
            }else if(order.orderStatus==="Cancelled"){
                badge="bg-danger";
            }
        %>

        <span class="badge <%= badge %> fs-6 px-3 py-2">
            <%= order.orderStatus %>
        </span>

    </div>



    <!-- Order Information -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-white">

            <h5 class="mb-0">
                Order Information
            </h5>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">

                    <p>
                        <strong>Order ID :</strong>
                        <%= order._id %>
                    </p>

                    <p>
                        <strong>Customer :</strong>
                        <%= order.customerName %>
                    </p>

                </div>

                <div class="col-md-6">

                    <p>
                        <strong>Order Date :</strong>
                        <%= new Date(order.createdAt).toLocaleDateString() %>
                    </p>

                    <p>
                        <strong>Payment Method :</strong>
                        <%= order.paymentMethod %>
                    </p>

                    <p>

<strong>Payment Status :</strong>

<% if(order.paymentMethod==="Delivered" && order.paymentStatus === "Paid"){ %>

    <span class="badge bg-success">
        <i class="bi bi-check-circle"></i>
        Paid
    </span>


<% } else if(order.paymentStatus === "Pending"){ %>

    <span class="badge bg-warning text-dark">
        <i class="bi bi-clock"></i>
        Pending
    </span>


<% } else if(order.paymentStatus === "Failed"){ %>

    <span class="badge bg-danger">
        <i class="bi bi-x-circle"></i>
        Failed
    </span>


<% } else if(order.paymentStatus === "Refunded"){ %>

    <span class="badge bg-info text-dark">
        <i class="bi bi-arrow-return-left"></i>
        Refunded
    </span>


<% } else { %>

    <span class="badge bg-secondary">
        <%= order.paymentStatus %>
    </span>

<% } %>
                    </p>

                </div>

            </div>

        </div>

    </div>



    <!-- Shipping Address -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-white">

            <h5 class="mb-0">
                Shipping Address
            </h5>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">

                    <p>
                        <strong>Name :</strong>
                        <%= order.shippingAddress.fullName %>
                    </p>

                    <p>
                        <strong>Phone :</strong>
                        <%= order.shippingAddress.phone %>
                    </p>

                    <p>
                        <strong>Address :</strong>
                        <%= order.shippingAddress.address %>
                    </p>

                </div>

                <div class="col-md-6">

                    <p>
                        <strong>City :</strong>
                        <%= order.shippingAddress.city %>
                    </p>

                    <p>
                        <strong>State :</strong>
                        <%= order.shippingAddress.state %>
                    </p>

                    <p>
                        <strong>Pincode :</strong>
                        <%= order.shippingAddress.pincode %>
                    </p>

                </div>

            </div>

        </div>

    </div>



    <!-- Ordered Products -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-white">

            <h5 class="mb-0">
                Ordered Products
            </h5>

        </div>

        <div class="card-body">

            <% order.items.forEach(item=>{ %>

                <div class="row align-items-center border-bottom py-3">

                    <div class="col-md-6">

                        <h5 class="fw-bold mb-2">
                            <%= item.productName %>
                        </h5>

                        <p class="text-muted mb-1">
                            Price : ₹ <%= item.price %>
                        </p>

                    </div>

                    <div class="col-md-3">

                        <p class="mb-0">

                            Quantity :
                            <strong><%= item.quantity %></strong>

                        </p>

                    </div>

                    <div class="col-md-3 text-end">

                        <h5 class="text-success">

                            ₹ <%= item.subtotal %>

                        </h5>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>



    <!-- Order Summary -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-white">

            <h5 class="mb-0">
                Order Summary
            </h5>

        </div>

        <div class="card-body">

            <div class="d-flex justify-content-between mb-3">

                <span>Total Items</span>

                <strong>

                    <%= order.items.reduce((sum,item)=>sum+item.quantity,0) %>

                </strong>

            </div>

            <div class="d-flex justify-content-between mb-3">

                <span>Shipping Charge</span>

                <strong class="text-success">

                    FREE

                </strong>

            </div>

            <hr>

            <div class="d-flex justify-content-between">

                <h4 class="fw-bold">
                    Total Amount
                </h4>

                <h4 class="fw-bold text-success">
                    ₹ <%= order.totalAmount %>
                </h4>

            </div>

        </div>

    </div>



    <div class="d-flex justify-content-between">

        <a
            href="/api/orders"
            class="btn btn-outline-secondary"
        >

            <i class="bi bi-arrow-left me-2"></i>

            Back to My Orders

        </a>

    <% if(order.orderStatus === "Placed" || order.orderStatus === "Processing"){ %>

        <form action="/api/orders/<%= order._id %>/cancel" method="POST">
            <button
                type="submit"
                class="btn btn-danger w-100"
                onclick="return confirm('Are you sure you want to cancel this order?')">
                Cancel Order
            </button>
        </form>

    <% } %>

    </div>

</div>