<div class="container py-5">

    <div class="card shadow">

        <div class="card-header">

            <h3>

                Order Details

            </h3>

        </div>

        <div class="card-body">

            <p>

                <strong>Order ID :</strong>

                <%= order._id %>

            </p>

            <p>

                <strong>Status :</strong>

                <span class="badge bg-success">

                    <%= order.orderStatus %>

                </span>

            </p>

            <p>

                <strong>Payment :</strong>

                <%= order.paymentMethod %>

            </p>

            <p>

                <strong>Total :</strong>

                ₹ <%= order.totalAmount %>

            </p>

            <hr>

            <h4>

                Products

            </h4>

            <table class="table">

                <thead>

                    <tr>

                        <th>Image</th>

                        <th>Name</th>

                        <th>Price</th>

                        <th>Qty</th>

                        <th>Subtotal</th>

                    </tr>

                </thead>

                <tbody>

                <% order.items.forEach(item=>{ %>

                    <tr>

                        <td>

                            <img
                                src="/uploads/<%= item.image %>"
                                width="70">

                        </td>

                        <td>

                            <%= item.productName %>

                        </td>

                        <td>

                            ₹ <%= item.price %>

                        </td>

                        <td>

                            <%= item.quantity %>

                        </td>

                        <td>

                            ₹ <%= item.subtotal %>

                        </td>

                    </tr>

                <% }) %>

                </tbody>

            </table>

            <hr>

            <h5>

                Shipping Address

            </h5>

            <p>

                <%= order.shippingAddress %>

            </p>

        </div>

    </div>

</div>