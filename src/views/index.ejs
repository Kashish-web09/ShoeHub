<!-- ================= HERO SECTION ================= -->

<section class="bg-light py-5">

    <div class="container">

        <div class="row align-items-center g-5">

            <div class="col-lg-6 text-center text-lg-start">

                <span class="badge bg-warning text-dark mb-3 px-3 py-2">
                    New Collection 2026
                </span>

                <h1 class="display-4 fw-bold">
                    Find Your Perfect Pair
                </h1>

                <p class="lead text-muted my-4">
                    Discover premium footwear designed for comfort, performance,
                    and everyday style.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">

                    <a
                        href="/api/products"
                        class="btn btn-warning btn-lg px-4">

                        <i class="bi bi-bag-fill me-2"></i>

                        Shop Now

                    </a>

                    <a
                        href="/api/products"
                        class="btn btn-outline-dark btn-lg px-4">

                        Explore Collection

                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img
                    src="/images/banner_img/banner_img1.jfif"
                    class="img-fluid rounded-4 shadow"
                    style="max-height:420px;"
                    alt="Banner">

            </div>

        </div>

    </div>

</section>

<!-- ================= NEW ARRIVALS ================= -->

<section class="py-5">

    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold mb-1">
                    New Arrivals
                </h2>

                <p class="text-muted mb-0">
                    Fresh styles just arrived.
                </p>

            </div>

            <a
                href="/api/products"
                class="btn btn-outline-dark">

                View All

            </a>

        </div>

        <div class="row g-4">

            <% products.forEach(p=>{ %>

            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">

                <div class="card border-0 shadow-sm h-100">

                    <img
                        src="/uploads/<%= p.thumbnail %>"
                        class="card-img-top"
                        style="height:250px;object-fit:cover;"
                        alt="<%= p.name %>">

                    <div class="card-body d-flex flex-column">

                        <span class="badge bg-light text-dark border align-self-start mb-2">

                            <%= p.category %>

                        </span>

                        <h5 class="fw-bold mb-3"
                        style="height: 72px;overflow: hidden;">

                            <%= p.name %>

                        </h5>

                        <h4 class="text-success fw-bold mv-3">

                            ₹<%= p.price %>

                        </h4>

<a href="/api/product_details/details/<%= p._id %>"
   class="btn btn-warning w-100 mt-auto">
    <i class="bi bi-eye-fill me-2"></i>
    View Product
</a>

                    </div>

                </div>

            </div>

            <% }) %>

        </div>

    </div>

</section>

<!-- ================= BEST SELLER ================= -->

<section class="bg-light py-5">

    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold mb-1">
                    Best Sellers
                </h2>

                <p class="text-muted mb-0">
                    Customer favourites.
                </p>

            </div>

            <a
                href="/api/products"
                class="btn btn-outline-dark">

                View All

            </a>

        </div>

        <div class="row g-4">

            <% if(bestSeller.length>0){ %>

                <% bestSeller.forEach(product=>{ %>

                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">

                    <div class="card border-0 shadow-sm h-100">

                        <img
                            src="/uploads/<%= product.thumbnail %>"
                            class="card-img-top"
                            style="height:250px;object-fit:cover;"
                            alt="<%= product.name %>">

                        <div class="card-body d-flex flex-column">

                            <span class="badge bg-success align-self-start mb-2">

                                Best Seller

                            </span>

<h5
    class="fw-bold mb-3"
    style="height:72px; overflow:hidden;">
    <%=product.name %>
</h5>
                            <h4 class="text-success fw-bold mb-3">

                                ₹<%= product.price %>

                            </h4>

<a href="/api/product_details/details/<%= product._id %>"
   class="btn btn-warning w-100 mt-auto">
    <i class="bi bi-eye-fill me-2"></i>
    View Product
</a>

                        </div>

                    </div>

                </div>

                <% }) %>

            <% } else { %>

                <div class="col-12">

                    <div class="card border-0 shadow-sm">

                        <div class="card-body text-center py-5">

                            <i class="bi bi-box display-3 text-secondary"></i>

                            <h4 class="mt-3">

                                No Best Seller Products Available

                            </h4>

                        </div>

                    </div>

                </div>

            <% } %>

        </div>

    </div>

</section>

