<!-- ================= HERO SECTION ================= -->
<section class="bg-light py-5"> 
    <div class="container">
         <div class="row align-items-center">
             <div class="col-md-6"> 
                <h1 class="fw-bold">Find Your Perfect Pair</h1> 
                <p>Discover the latest trends in footwear. Shop the best collection of stylish shoes.</p> 
                <button class="btn btn-warning">Shop Now</button> </div>
                 <div class="col-md-6 d-flex justify-content-center"> 
                    <img src="/images/banner_img/banner_img1.jfif" class="img-fluid" style="max-height:250px;">
                 </div> 
                </div>
             </div> 
            </section>


<!-- ================= NEW ARRIVALS ================= -->
<section class="py-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">New Arrivals</h2>
            <button class="btn btn-dark btn-sm px-4">View All</button>
        </div>

<div class="row g-4">

<% products.forEach(p=>{ %>

<div class="col-lg-3 col-md-4 col-sm-6">

<div class="card product-card h-100">

<div class="image-box">
<img src="/uploads/<%= p.thumbnail %>" alt="<%= p.name %>">
</div>

<div class="card-body">

<span class="category">
<%= p.category %>
</span>

<h5 class="product-name">
<%= p.name %>
</h5>

<div class="price">
₹<%= p.price %>
</div>

<div class="d-grid gap-2 mt-4">

<form action="/api/cart" method="POST">

<input type="hidden" name="productId" value="<%= p._id %>">

<button class="btn btn-cart">
<i class="bi bi-cart-fill"></i>
Add to Cart
</button>

</form>

<form action="/api/wishlist" method="POST">

<input type="hidden" name="productId" value="<%= p._id %>">

<button class="btn btn-wishlist">
<i class="bi bi-heart"></i>
Wishlist
</button>

</form>

</div>

</div>

</div>

</div>

<% }) %>

</div>
</div>

</section>


<!-- ================= BEST SELLER ================= -->
<section class="py-5 bg-light">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Best Seller</h2>
            <a href="/products" class="btn btn-dark btn-sm px-4">View All</a>
        </div>

        <div class="row g-4">

            <% if(bestSeller.length > 0){ %>

                <% bestSeller.forEach(product=>{ %>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 shadow-sm">


<img
    src="/uploads/<%= product.thumbnail %>"
    style="width:200px">
                            <div class="card-body d-flex flex-column text-center">

                                <h5 class="card-title">
                                    <%= product.name %>
                                </h5>

                                <p class="card-price">
                                    ₹<%= product.price %>
                                </p>

                                <a href="/products/<%= product._id %>"
                                   class="btn btn-warning mt-auto w-100">
                                    View Product
                                </a>

                            </div>

                        </div>
                    </div>

                <% }) %>

            <% } else { %>

                <div class="col-12 text-center">
                    <h5>No Best Seller Products Available</h5>
                </div>

            <% } %>

        </div>

    </div>
</section>


<!-- ================= TOP BRANDS ================= -->
<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4">Top Brands</h2>

        <div class="row g-4 text-center brand-logo">

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/nike_logo.png" alt="Nike">
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/adidia_logo.png" alt="Adidas">
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/puma_logo.jfif" alt="Puma">
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/reebook_logo.jfif" alt="Reebok">
                </div>
            </div>

        </div>
    </div>
</section>


