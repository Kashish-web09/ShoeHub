<main class="bg-light py-5">

<div class="container">

<div class="row g-4">

    <!-- Left Profile Card -->

    <div class="col-lg-4">

        <div class="card border-0 shadow-sm">

            <div class="card-body text-center p-5">

                <div
                    class="rounded-circle bg-warning d-inline-flex justify-content-center align-items-center mb-3"
                    style="width:120px;height:120px;">

                    <i class="bi bi-person-fill text-white" style="font-size:65px;"></i>

                </div>

                <h3 class="fw-bold">

                    <%= user.name %>

                </h3>

                <p class="text-muted mb-1">

                    <%= user.email %>

                </p>

                <span class="badge bg-success">

                    Customer

                </span>

                <hr>

                <div class="d-grid gap-2">

                    <a
                        href="/api/users/edit-profile"
                        class="btn btn-warning">

                        <i class="bi bi-pencil-square me-2"></i>

                        Edit Profile

                    </a>

                    <a
                        href="/api/users/logout"
                        class="btn btn-outline-danger">

                        <i class="bi bi-box-arrow-right me-2"></i>

                        Logout

                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- Right Side -->

    <div class="col-lg-8">

        <!-- Personal Information -->

        <div class="card border-0 shadow-sm mb-4">

            <div class="card-header bg-dark text-white">

                <h5 class="mb-0">

                    Personal Information

                </h5>

            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-4">

                        <small class="text-muted">

                            Full Name

                        </small>

                        <h6>

                            <%= user.name %>

                        </h6>

                    </div>

                    <div class="col-md-6 mb-4">

                        <small class="text-muted">

                            Email

                        </small>

                        <h6>

                            <%= user.email %>

                        </h6>

                    </div>

                    <div class="col-md-6 mb-4">

                        <small class="text-muted">

                            Phone

                        </small>

                        <h6>

                            <%= user.phone || "Not Added" %>

                        </h6>

                    </div>

                    <div class="col-md-6 mb-4">

                        <small class="text-muted">

                            Member Since

                        </small>

                        <h6>

                            <%= new Date(user.createdAt).toLocaleDateString() %>

                        </h6>

                    </div>

                </div>

            </div>

        </div>

        <!-- Quick Actions -->

        <div class="card border-0 shadow-sm">

            <div class="card-header bg-warning">

                <h5 class="mb-0">

                    Quick Actions

                </h5>

            </div>

            <div class="card-body">

                <div class="row g-4">

                    <div class="col-md-3 col-6">

                        <a
                            href="/api/orders"
                            class="btn btn-outline-dark w-100 py-4">

                            <i class="bi bi-box-seam display-6 d-block mb-2"></i>

                            My Orders

                        </a>

                    </div>

                    <div class="col-md-3 col-6">

                        <a
                            href="/api/cart"
                            class="btn btn-outline-dark w-100 py-4">

                            <i class="bi bi-cart3 display-6 d-block mb-2"></i>

                            Cart

                        </a>

                    </div>

                    <div class="col-md-3 col-6">

                        <a
                            href="/api/wishlist"
                            class="btn btn-outline-dark w-100 py-4">

                            <i class="bi bi-heart display-6 d-block mb-2"></i>

                            Wishlist

                        </a>

                    </div>

                    <div class="col-md-3 col-6">

                        <a
                            href="/api/users/change-password"
                            class="btn btn-outline-dark w-100 py-4">

                            <i class="bi bi-lock display-6 d-block mb-2"></i>

                            Password

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

</div>

</main>