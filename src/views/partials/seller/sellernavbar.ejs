<!-- Desktop Sidebar -->
<div class="seller-sidebar d-none d-lg-block bg-dark text-white shadow">

    <!-- Logo -->
    <div class="text-center py-4 border-bottom border-secondary">
        <h3 class="fw-bold mb-0">
            🛍 Seller Panel
        </h3>
    </div>


    <!-- Seller Profile -->
    <div class="text-center py-4">

        <img
            src="/uploads/<%= seller.profileImage %>"
            class="rounded-circle border border-3 border-light"
            width="90"
            height="90"
            style="object-fit:cover;">

        <h5 class="mt-3 mb-1">
            <%= seller.name %>
        </h5>

        <p class="small mb-2">
            <%= seller.email %>
        </p>

        <span class="badge bg-primary">
            Seller
        </span>

    </div>


    <!-- Menu -->
    <div class="list-group list-group-flush">

        <a href="/api/seller/dashboard"
        class="list-group-item list-group-item-action bg-dark text-white border-secondary">
            📊 Dashboard
        </a>


        <a href="/api/seller/product"
        class="list-group-item list-group-item-action bg-dark text-white border-secondary">
            📦 Products
        </a>


        <a href="/api/seller/product/add-product"
        class="list-group-item list-group-item-action bg-dark text-white border-secondary">
            ➕ Add Product
        </a>


        <a href="/api/seller/orders"
        class="list-group-item list-group-item-action bg-dark text-white border-secondary">
            🛒 Orders
        </a>


        <a href="/api/seller/feedback"
        class="list-group-item list-group-item-action bg-dark text-white border-secondary">
            ⭐ Feedback
        </a>


        <a href="/api/seller/profile"
        class="list-group-item list-group-item-action bg-dark text-white border-secondary">
            👤 Profile
        </a>


        <a href="/api/seller/logout"
        class="list-group-item list-group-item-action bg-dark text-danger border-secondary">
            🚪 Logout
        </a>

    </div>

</div>



<!-- Mobile / Tablet Offcanvas Sidebar -->

<div class="offcanvas offcanvas-start bg-dark text-white"
id="sellerMenu">

    <div class="offcanvas-header border-bottom">

        <h5 class="fw-bold">
            🛍 Seller Panel
        </h5>

        <button class="btn-close btn-close-white"
        data-bs-dismiss="offcanvas"></button>

    </div>


    <div class="offcanvas-body">


        <div class="text-center">

            <img
            src="/uploads/<%= seller.profileImage %>"
            class="rounded-circle border border-3"
            width="80"
            height="80"
            style="object-fit:cover;">


            <h5 class="mt-3">
                <%= seller.name %>
            </h5>


            <p>
                <%= seller.email %>
            </p>

        </div>


        <div class="list-group mt-4">


            <a href="/api/seller/dashboard"
            class="list-group-item">
            📊 Dashboard
            </a>


            <a href="/api/seller/product"
            class="list-group-item">
            📦 Products
            </a>


            <a href="/api/seller/product/add-product"
            class="list-group-item">
            ➕ Add Product
            </a>


            <a href="/api/seller/orders"
            class="list-group-item">
            🛒 Orders
            </a>


            <a href="/api/seller/feedback"
            class="list-group-item">
            ⭐ Feedback
            </a>


            <a href="/api/seller/profile"
            class="list-group-item">
            👤 Profile
            </a>


            <a href="/api/seller/logout"
            class="list-group-item text-danger">
            🚪 Logout
            </a>


        </div>


    </div>

</div>




<!-- Top Navbar -->

<nav class="navbar bg-white shadow-sm">

    <div class="container-fluid">


        <!-- Mobile Menu Button -->

        <button class="btn btn-dark d-lg-none"
        data-bs-toggle="offcanvas"
        data-bs-target="#sellerMenu">

            ☰

        </button>



        <span class="navbar-brand fw-bold ms-2">

            <%= title %>

        </span>



        <div class="d-none d-md-flex align-items-center">


            <span class="me-3 fw-semibold">

                Welcome, <%= seller.name %>

            </span>


            <img
            src="/uploads/<%= seller.profileImage %>"
            class="rounded-circle"
            width="45"
            height="45"
            style="object-fit:cover;">


        </div>


    </div>

</nav>



<style>

.seller-sidebar{

    position:fixed;
    top:0;
    left:0;
    width:260px;
    height:100vh;
    overflow-y:auto;

}


.seller-content{

    margin-left:260px;
    padding:30px;

}


@media(max-width:991px){

    .seller-content{

        margin-left:0;
        padding:15px;

    }

}

</style>