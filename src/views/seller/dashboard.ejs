<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Seller Dashboard</h2>
            <p class="text-muted mb-0">Welcome back! Here's an overview of your store.</p>
        </div>

        <a href="/api/seller/product/add-product" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Add Product
        </a>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-5">

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill fs-1 text-primary"></i>
                    <h5 class="mt-3">Users</h5>
                    <h2><%= totalUsers %></h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-box-seam fs-1 text-success"></i>
                    <h5 class="mt-3">Products</h5>
                    <h2><%= totalProducts %></h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-cart-check fs-1 text-warning"></i>
                    <h5 class="mt-3">Orders</h5>
                    <h2><%= totalOrders %></h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-currency-rupee fs-1 text-danger"></i>
                    <h5 class="mt-3">Revenue</h5>
                    <h2>₹<%= revenue %></h2>
                </div>
            </div>
        </div>

    </div>

    <!-- Recent Orders -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0">Recent Orders</h5>
        </div>

        <div class="card-body">

            <% if(recentOrders.length > 0){ %>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% recentOrders.forEach(order=>{ %>

                        <tr>

                            <td>#<%= order._id %></td>

                            <td><%= order.user %></td>

                            <td>₹<%= order.total %></td>

                            <td>
                                <span class="badge bg-success">
                                    <%= order.status %>
                                </span>
                            </td>

                        </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

            <% } else { %>

            <div class="text-center py-5">

                <i class="bi bi-cart-x display-3 text-secondary"></i>

                <h4 class="mt-3">No Orders Yet</h4>

                <p class="text-muted">
                    Recent orders will appear here.
                </p>

            </div>

            <% } %>

        </div>

    </div>

</div>