<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Out of Stock Products</h2>
            <p class="text-muted">Products that need to be restocked.</p>
        </div>

        <a href="/api/seller/product" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Back to Products
        </a>
    </div>

    <% if(products.length === 0){ %>

        <div class="alert alert-success text-center">
            🎉 Great! You have no out-of-stock products.
        </div>

    <% } else { %>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                <% products.forEach(product => { %>

                <tr>
                    <td>
                        <img src="/uploads/<%= product.thumbnail %>" width="70" height="70"
                             class="rounded object-fit-cover">
                    </td>

                    <td><%= product.name %></td>

                    <td><%= product.category %></td>

                    <td>₹<%= product.price %></td>

                    <td>
                        <span class="badge bg-danger">
                            <%= product.stock %>
                        </span>
                    </td>

                    <td>
                        <span class="badge bg-warning text-dark">
                            Out of Stock
                        </span>
                    </td>
                    <td>
    <a href="/api/seller/product/edit/<%= product._id %>"
       class="btn btn-warning btn-sm">
        <i class="bi bi-pencil"></i> Edit
    </a>
</td>
                </tr>

                <% }) %>
            </tbody>
        </table>
    </div>

    <% } %>

</div>