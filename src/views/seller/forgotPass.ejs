<section class="bg-light d-flex align-items-center justify-content-center py-5" style="min-height:90vh;">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-12 col-sm-10 col-md-7 col-lg-5">

                <div class="card shadow-lg border-0 rounded-4">

                    <div class="card-body p-4 p-md-5">

                        <!-- Icon -->
                        <div class="text-center mb-4">

                            <div class="mb-3">
                                <i class="fa-solid fa-key display-4 text-warning"></i>
                            </div>

                            <h2 class="fw-bold">
                                Forgot Password?
                            </h2>

                            <p class="text-muted">
                                Enter your registered seller email and we will send you a password reset link.
                            </p>

                        </div>


                        <!-- Form -->
                        <form action="/api/seller/forgotPass" method="POST">


                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Email Address
                                </label>

                                <div class="input-group">

                                    <span class="input-group-text bg-warning">
                                        <i class="fa-solid fa-envelope"></i>
                                    </span>

                                    <input
                                        type="email"
                                        name="email"
                                        class="form-control form-control-lg"
                                        placeholder="seller@example.com"
                                        required
                                    >

                                </div>

                            </div>


                            <button
                                type="submit"
                                class="btn btn-warning btn-lg w-100 fw-semibold">

                                <i class="fa-solid fa-paper-plane me-2"></i>

                                Send Reset Link

                            </button>


                        </form>


                        <hr class="my-4">


                        <div class="text-center">

                            <a
                                href="/api/seller/login"
                                class="text-decoration-none fw-semibold">

                                <i class="fa-solid fa-arrow-left me-2"></i>

                                Back to Seller Login

                            </a>

                        </div>


                    </div>

                </div>

            </div>

        </div>

    </div>

</section>