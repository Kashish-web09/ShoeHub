<div class="container-fluid py-3 py-md-4">


    <!-- Header -->

    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">


        <div>

            <h2 class="fw-bold mb-1">
                Product Management
            </h2>

            <p class="text-muted mb-0">
                Manage all your products from one place.
            </p>

        </div>

<!-- Product Filter -->
<!-- Product Filter -->
<form action="/api/seller/product/filter" method="GET" class="card shadow-sm border-0 mb-4">

    <div class="card-body">

        <div class="row g-3">

            <!-- Gender -->
            <div class="col-lg-3 col-md-6">

                <label class="form-label fw-semibold">
                    Gender
                </label>

                <select name="gender" class="form-select">

                    <option value="">All Genders</option>

                    <option value="Mens"
                        <%= gender==="Mens" ? "selected" : "" %>>
                        Mens
                    </option>

                    <option value="Womens"
                        <%= gender==="Womens" ? "selected" : "" %>>
                        Womens
                    </option>


                </select>

            </div>

            <!-- Category -->
            <div class="col-lg-3 col-md-6">

                <label class="form-label fw-semibold">
                    Category
                </label>

                <select name="category" class="form-select">

                    <option value="">All Categories</option>

                    <option value="Running"
                        <%= category==="Running" ? "selected" : "" %>>
                        Running
                    </option>

                    <option value="Sneakers"
                        <%= category==="Sneakers" ? "selected" : "" %>>
                        Sneakers
                    </option>

                    <option value="Sports"
                        <%= category==="Sports" ? "selected" : "" %>>
                        Sports
                    </option>

                    <option value="Casual"
                        <%= category==="Casual" ? "selected" : "" %>>
                        Casual
                    </option>

                    <option value="Formal"
                        <%= category==="Formal" ? "selected" : "" %>>
                        Formal
                    </option>

                    <option value="Boots"
                        <%= category==="Boots" ? "selected" : "" %>>
                        Boots
                    </option>

                    <option value="Sandals"
                        <%= category==="Sandals" ? "selected" : "" %>>
                        Sandals
                    </option>

                    <option value="Slippers"
                        <%= category==="Slippers" ? "selected" : "" %>>
                        Slippers
                    </option>

                </select>

            </div>

            <!-- Price -->
            <div class="col-lg-3 col-md-6">

                <label class="form-label fw-semibold">
                    Price Range
                </label>

                <select name="price" class="form-select">

                    <option value="">All Prices</option>

                    <option value="0-2000"
                        <%= price==="0-2000" ? "selected" : "" %>>
                        ₹0 - ₹2,000
                    </option>

                    <option value="2001-5000"
                        <%= price==="2001-5000" ? "selected" : "" %>>
                        ₹2,001 - ₹5,000
                    </option>

                    <option value="5001-10000"
                        <%= price==="5001-10000" ? "selected" : "" %>>
                        ₹5,001 - ₹10,000
                    </option>

                    <option value="10001-20000"
                        <%= price==="10001-20000" ? "selected" : "" %>>
                        ₹10,001 - ₹20,000
                    </option>

                    <option value="20000+"
                        <%= price==="20000+" ? "selected" : "" %>>
                        Above ₹20,000
                    </option>

                </select>

            </div>

            <!-- Buttons -->
            <div class="col-lg-3 col-md-6">

                <label class="form-label d-block">&nbsp;</label>

                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-funnel-fill"></i>
                        Filter
                    </button>

                    <a href="/api/seller/product" class="btn btn-outline-secondary flex-fill">
                        Reset
                    </a>

                </div>

            </div>

        </div>

    </div>

</form>



<div class="d-flex justify-content-end align-items-center gap-3 mb-4">

    <a href="/api/seller/product/add-product"
       class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
        <i class="bi bi-plus-circle me-2"></i>
        Add Product
    </a>

    <a href="/api/seller/product/out-of-stock-product"
       class="btn btn-outline-danger px-4 py-2 rounded-3 shadow-sm">
        <i class="bi bi-exclamation-circle me-2"></i>
        Out of Stock
    </a>

</div>    </div>
  <!-- Products Table -->


    <div class="card shadow-sm border-0">



        <div class="card-header bg-white">


            <h5 class="mb-0">
                All Products
            </h5>


        </div>

 <div class="card-body p-0">



            <div class="table-responsive">



                <table class="table table-hover align-middle mb-0">



                    <thead class="table-light">


                    <tr>

                        <th>#</th>

                        <th>
                            Image
                        </th>

                        <th>
                            Name
                        </th>

                        <th>
                            Category
                        </th>

                        <th>
                            Gender
                        </th>

                        <th>
                            Price
                        </th>

                        <th>
                            Stock
                        </th>

                        <th>
                            Best Seller
                        </th>

                        <th class="text-center">
                            Actions
                        </th>

                    </tr>


                    </thead>

                    <tbody>

                    <% if(products && products.length > 0){ %>




                    <% products.forEach((product,index)=>{ %>




                        <tr>


                            <td>
                                <%= index+1 %>
                            </td>





                            <td>


                            <% if(product.thumbnail){ %>


                                <img
                                src="/uploads/<%= product.thumbnail %>"
                                width="60"
                                height="60"
                                class="rounded border"
                                style="object-fit:cover;">



                            <% }else{ %>


                                <span class="text-muted">
                                    No Image
                                </span>


                            <% } %>


                            </td>
     <td class="fw-semibold text-nowrap">

                                <%= product.name %>

                            </td>






                            <td>

                                <%= product.category %>

                            </td>






                            <td>

                                <%= product.gender %>

                            </td>






                            <td class="text-nowrap">

                                ₹<%= product.price %>

                            </td>








                            <td>


                            <% if(product.stock>0){ %>


                                <span class="badge bg-success">

                                    <%= product.stock %>

                                </span>




                            <% } else { %>



                                <span class="badge bg-danger">

                                    Out of Stock

                                </span>




                            <% } %>


                            </td>








                            <td>



                            <% if(product.isBestSeller){ %>


                                <span class="badge bg-success">

                                    Best Seller

                                </span>




                            <% }else{ %>



                                <span class="badge bg-secondary">

                                    No

                                </span>




                            <% } %>



                            </td>








                            <td>


                                <div class="d-flex gap-2">



                                    <a
                                    href="/api/seller/product/edit/<%= product._id %>"
                                    class="btn btn-warning btn-sm">


                                        <i class="bi bi-pencil-square"></i>


                                    </a>





                                    <a
                                    href="/api/seller/product/delete/<%=product._id %>"
                                    class="btn btn-danger btn-sm">


                                        <i class="bi bi-trash"></i>


                                    </a>






                                    <a
                                    href="/api/seller/product/details/<%=product._id%>"
                                    class="btn btn-primary btn-sm">


                                        View


                                    </a>




                                </div>



                            </td>





                        </tr>




                    <% }) %>






                    <% }else{ %>





                        <tr>


                            <td colspan="9"
                            class="text-center py-5">


                                <h5 class="text-muted">

                                    No Products Found

                                </h5>



                                <a
                                href="/api/seller/product/add-product"
                                class="btn btn-primary mt-3">


                                    Add First Product


                                </a>



                            </td>



                        </tr>





                    <% } %>





                    </tbody>



                </table>




            </div>




        </div>



    </div>



</div>