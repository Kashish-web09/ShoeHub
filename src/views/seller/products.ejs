<div class="container-fluid py-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Product Management</h2>
        <p class="text-muted mb-0">Manage all your products from one place.</p>
    </div>

    <div class="d-flex gap-2">
        <a href="/api/seller/product/out-of-stock-product" class="btn btn-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>Out of Stock
        </a>

        <a href="/api/seller/product/add-product" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Add Product
        </a>
    </div>
</div>

    <!-- Search -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form action="/api/seller/product" method="GET">
                <div class="row g-3">

                    <div class="col-md-10">
                        <input
                            type="text"
                            name="search"
                            class="form-control"
                            placeholder="Search product by name...">
                    </div>

                    <div class="col-md-2 d-grid">
                        <button class="btn btn-dark">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0">All Products</h5>
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                    <tr>

                        <th>#</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Gender</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Best Seller</th>
                        <th class="text-center">Actions</th>

                    </tr>

                    </thead>

                    <tbody>

                    <% if(products && products.length > 0){ %>

                        <% products.forEach((product,index)=>{ %>

                        <tr>

                            <td>
                                <%= index+1 %>
                            </td>

                            <td>

                                <% if(product.thumbnail){ %>

                                <img
                                    src="/uploads/<%= product.thumbnail %>"
                                    class="rounded"
                                    width="70"
                                    height="70"
                                    style="object-fit:cover;">

                                <% }else{ %>

                                    <span class="text-muted">
                                        No Image
                                    </span>

                                <% } %>

                            </td>

                            <td class="fw-semibold">
                                <%= product.name %>
                            </td>

                            <td>
                                <%= product.category %>
                            </td>
<td><%= product.gender %></td>
                            <td>
                                ₹<%= product.price %>
                            </td>
<td>
    <% if(product.stock>0){ %>
 <span class="badge bg-success">
    <%= product.stock %>
 </span>
   <% } else { %>
    <span class="badge bg-danger">
        Out of Stock
    </span>
    <% } %>
</td>
                            <td>

                                <% if(product.isBestSeller){ %>

                                    <span class="badge bg-success">
                                        Best Seller
                                    </span>

                                <% }else{ %>

                                    <span class="badge bg-secondary">
                                        No
                                    </span>

                                <% } %>

                            </td>

                            <td class="text-center">

                                <a
                                    href="/api/seller/product/edit/<%= product._id %>"
                                    class="btn btn-warning btn-sm me-2">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

            
                            </td>
                            <td class="text-center">
                                <a href="/api/seller/product/delete/<%=product._id %>"
                                    class="btn btn-danger btn-sm me-2">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>

                        </tr>

                        <% }) %>

                    <% }else{ %>

                        <tr>

                            <td colspan="7" class="text-center py-5">

                                <h5 class="text-muted">
                                    No Products Found
                                </h5>

                                <a
                                    href="/api/seller/product/add-product"
                                    class="btn btn-primary mt-3">

                                    Add First Product

                                </a>

                            </td>

                        </tr>

                    <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>