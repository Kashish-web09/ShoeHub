<div class="container py-5">

    <div class="text-center mb-5">
        <h2 class="fw-bold">My Account</h2>
        <p class="text-muted">
            Welcome back, <strong><%= user.name %></strong> 👋
        </p>
    </div>

    <div class="card shadow border-0 rounded-4 mb-5">

        <div class="card-body p-4">

            <div class="row align-items-center">

                <div class="col-md-3 text-center">

                    <% if(user.image){ %>

                        <img
                            src="/uploads/<%= user.image %>"
                            class="rounded-circle border shadow"
                            width="170"
                            height="170"
                            style="object-fit:cover;"
                        >

                    <% } else { %>

                        <img
                            src="https://ui-avatars.com/api/?name=<%= user.name %>&background=0d6efd&color=fff&size=170"
                            class="rounded-circle border shadow"
                        >

                    <% } %>

                </div>

                <div class="col-md-9">

                    <h3 class="fw-bold mb-3">
                        <%= user.name %>
                    </h3>

                    <p class="mb-2">
                        <strong>Email :</strong>
                        <%= user.email %>
                    </p>

                    <p class="text-muted">
                        Customer Account
                    </p>

                    <a
                        href="/api/profile/update"
                        class="btn btn-dark mt-2"
                    >
                        Edit Profile
                    </a>

                </div>

            </div>

        </div>

    </div>

    <h4 class="fw-bold mb-4">
        Quick Actions
    </h4>

    <div class="row g-4">

        <div class="col-md-4">

            <a
                href="/api/orders"
                class="text-decoration-none text-dark"
            >

                <div class="card shadow-sm h-100">

                    <div class="card-body text-center p-4">

                        <h1>📦</h1>

                        <h5 class="fw-bold">
                            My Orders
                        </h5>

                        <p class="text-muted">
                            View all your orders
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-4">

            <a
                href="/api/cart"
                class="text-decoration-none text-dark"
            >

                <div class="card shadow-sm h-100">

                    <div class="card-body text-center p-4">

                        <h1>🛒</h1>

                        <h5 class="fw-bold">
                            My Cart
                        </h5>

                        <p class="text-muted">
                            View shopping cart
                        </p>

                    </div>

                </div>

            </a>

        </div>



        <div class="col-md-4">

            <a
                href="/api/profile/update"
                class="text-decoration-none text-dark"
            >

                <div class="card shadow-sm h-100">

                    <div class="card-body text-center p-4">

                        <h1>👤</h1>

                        <h5 class="fw-bold">
                            Edit Profile
                        </h5>

                        <p class="text-muted">
                            Update your information
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-4">

            <a
                href="/api/users/logout"
                class="text-decoration-none text-dark"
            >

                <div class="card shadow-sm h-100">

                    <div class="card-body text-center p-4">

                        <h1>🚪</h1>

                        <h5 class="fw-bold">
                            Logout
                        </h5>

                        <p class="text-muted">
                            Securely sign out
                        </p>

                    </div>

                </div>

            </a>

        </div>

    </div>

</div>